# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan

# Exception for environments (required for CI/CD)
 !environments/**/*.tfvars

# Backup files
*.backup
*.bak

# Log files
*.log

# Zips generados por Terraform (archive_file) en el módulo serverless
modules/serverless/builds/*.zip

# Dependencias empaquetadas para Lambda (Python)
modules/serverless/lambda/consumer/package/__pycache__/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Provider lock (opcional - descomenta si quieres locking de versiones)
# .terraform.lock.hcl
.agents
